{
  "name": "@repo/database",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../prisma/.env -- prisma generate",
    "migrate:dev": "dotenv -e ../../prisma/.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../prisma/.env -- prisma migrate deploy",
    "migrate:reset": "dotenv -e ../../prisma/.env -- prisma migrate reset",
    "migrate:status": "dotenv -e ../../prisma/.env -- prisma migrate status",
    "migrate:diff": "dotenv -e ../../prisma/.env -- prisma migrate diff --from-local-db --to-schema-datamodel ../../prisma/schema.prisma --script",
    "validate": "dotenv -e ../../prisma/.env -- prisma validate",
    "format": "dotenv -e ../../prisma/.env -- prisma format",
    "format:check": "dotenv -e ../../prisma/.env -- prisma format --check",
    "studio": "dotenv -e ../../prisma/.env -- prisma studio",
    "seed": "tsx --env-file=../../prisma/.env ../../prisma/seed.ts",
    "clean": "rm -rf dist node_modules/.prisma"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma",
    "seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/node": "^22.10.7",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
