auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false

# Hoist Prisma to root so `prisma generate` (run with schema at root) can write
# to root node_modules and all workspace packages can import @prisma/client.
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/client
public-hoist-pattern[]=@prisma/engines
public-hoist-pattern[]=@prisma/engines-version

# Hoist ESLint binary to root so packages with lint scripts can find it.
public-hoist-pattern[]=eslint
public-hoist-pattern[]=eslint-*
public-hoist-pattern[]=@eslint*
public-hoist-pattern[]=typescript-eslint
public-hoist-pattern[]=@typescript-eslint*

# Hoist Prettier plugin so format:check run from root can find it.
public-hoist-pattern[]=prettier-plugin-tailwindcss
